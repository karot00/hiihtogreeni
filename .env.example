# ============================================================================
# Hiihtogreeni.fi — environment variables (EXAMPLE / TEMPLATE)
# Copy to `.env.local` for local dev, or import these keys into Vercel.
# NEVER commit a real `.env.local` — `.env*` is gitignored.
# Never expose a SERVER key (RESEND_*) to the browser; only NEXT_PUBLIC_* reach
# the client bundle by design.
# ============================================================================

# ----------------------------------------------------------------------------
# Phase 6 / Phase 10 — Contact-form email delivery (Resend)
# ----------------------------------------------------------------------------
# Server-side only. Create at https://resend.com/api-keys and keep it secret.
# The sending domain "hiihtogreeni.fi" MUST be verified in Resend (DNS: SPF,
# DKIM, DMARC) before production delivery works. Without this key the contact
# route returns 503 (mail-unavailable) but the site still renders and builds.
RESEND_API_KEY=

# Optional override for the recipient mailbox. Defaults to the owner-approved
# hiihtogreeni@hiihtogreeni.fi if unset.
# CONTACT_RECIPIENT=hiihtogreeni@hiihtogreeni.fi

# Sender identity used in the From header. Must be on the verified domain.
# Defaults to "Hiihtogreeni website <website@hiihtogreeni.fi>" in code.
# CONTACT_SENDER=Hiihtogreeni website <website@hiihtogreeni.fi>

# ----------------------------------------------------------------------------
# Phase 10 — Production origin (optional override)
# ----------------------------------------------------------------------------
# The canonical production origin is hardcoded to https://www.hiihtogreeni.fi
# in the root layouts' metadataBase (per REBUILD-PLAN Phase 7). Set this only
# if you need to point metadata at a different origin without a code change
# (e.g. a temporary test hostname during pre-cutover validation).
# SITE_URL=https://www.hiihtogreeni.fi

# ----------------------------------------------------------------------------
# Phase 13 (deferred) — Cookie consent integration point
# ----------------------------------------------------------------------------
# The separately supplied consent implementation will read these. Unused until
# Phase 13; do not set before that work begins.
# COOKIE_CONSENT_API_URL=
# COOKIE_CONSENT_SITE_ID=

# ----------------------------------------------------------------------------
# Phase 14 (deferred) — GA4 analytics (consent-gated, NOT a launch blocker)
# ----------------------------------------------------------------------------
# Public/web-stream measurement ID. Safe to ship in the client ONLY after the
# consent solution is active and defaults to denied. Do NOT add until Phase 14.
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=
